# air learn (scheduled) — PER-CALLER stub. Copy this into a PRIVATE fleet repo as
# `.github/workflows/air-learn-cron.yml`. It runs the repo's OWN out-of-band learn
# on a daily schedule, using the repo's OWN secrets — keeping every corporate
# credential and the fleet reach OFF the public air repo.
#
# Setup (per repo):
#   1. Secrets already present from reviews: ANTHROPIC_API_KEY (+ AIR_BOT_TOKEN for live).
#   2. Drop this file in as `.github/workflows/air-learn-cron.yml`, and PICK A
#      DISTINCT MINUTE for the schedule below — don't keep the stub's default.
#      Every repo copying this verbatim ticks at the same instant: their learn
#      runs then race the shared workspace API together (and GitHub delays or
#      drops schedules at popular minutes). Any minute unique-ish to the repo
#      works; spreading repos across the hour is enough.
#   3. Trial: leave the mode as-is → the daily tick runs `list` ($0, enumerate only).
#   4. Go-live (per repo, deliberate): set the repo/org VARIABLE
#      AIR_LEARN_CRON_LIVE=true. It does double duty (single-sourced): this cron
#      runs `live` on schedule, AND the review job automatically switches to
#      BUMP-ONLY (no inline learn) via review.py:_update_learn_counter — so the
#      cron is the SOLE learn executor with no double-fire. No code edit needed.
#      (Store-backed repos only — the cron doesn't service wiki-backed repos, so
#      the review job keeps learning inline there regardless of the variable.)

name: air learn (scheduled)

on:
  schedule:
    - cron: '23 6 * * *'   # daily 06:23 UTC — CHANGE the minute per repo (see setup step 2)
  workflow_dispatch:
    inputs:
      mode:
        description: 'list (enumerate, $0) | dry-run (curate, no write) | live (real)'
        type: choice
        options: [list, dry-run, live]
        default: dry-run

# One scheduled learn at a time for this repo — a long live curation must never
# stack on the next daily tick or a manual dispatch. (The reusable workflow also
# guards concurrency, and learn_cron itself claims a CAS lock in the store; this
# is the outermost of the three, stopping a second caller run before it even
# reaches the reusable workflow.)
concurrency:
  group: air-learn-caller-${{ github.repository }}
  cancel-in-progress: false

jobs:
  learn:
    uses: VorobiovD/air/.github/workflows/air-learn-cron.yml@main
    with:
      repo: ${{ github.repository }}
      # workflow_dispatch → the chosen mode; scheduled tick → 'live' only when this
      # repo's AIR_LEARN_CRON_LIVE var is set, else 'list' (trial-safe, $0).
      mode: >-
        ${{ github.event_name == 'workflow_dispatch'
            && inputs.mode
            || (vars.AIR_LEARN_CRON_LIVE == 'true' && 'live' || 'list') }}
    secrets: inherit   # passes THIS repo's ANTHROPIC_API_KEY + AIR_BOT_TOKEN

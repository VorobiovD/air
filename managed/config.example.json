{
  "environment_id": "env_YOUR_ENVIRONMENT_ID",
  "vault_id": "vlt_YOUR_VAULT_ID",
  "orchestrator": {
    "id": "agent_YOUR_ORCHESTRATOR_ID",
    "version": 1,
    "mode": "multi-agent"
  },
  "github_app": {
    "app_id": "YOUR_GITHUB_APP_ID",
    "installation_id": "YOUR_INSTALLATION_ID",
    "private_key_path": "~/path/to/your-app.private-key.pem"
  },
  "sub_agents": {
    "code-reviewer": { "id": "agent_...", "version": 1 },
    "simplify": { "id": "agent_...", "version": 1 },
    "security-auditor": { "id": "agent_...", "version": 1 },
    "git-history-reviewer": { "id": "agent_...", "version": 1 },
    "review-verifier": { "id": "agent_...", "version": 1 }
  }
}
